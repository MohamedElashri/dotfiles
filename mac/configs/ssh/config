# =========================
# General defaults
# Put broad rules last because first value wins
# =========================

Host *
    IdentityAgent ~/.1password/agent.sock
    AddKeysToAgent yes
    ForwardX11 yes
    ForwardAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 240
    ControlMaster auto
    ControlPath ~/.ssh/%r@%h:%p
    ControlPersist yes