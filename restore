#!/usr/bin/env bash

# Restore dotfiles from this repository into $HOME.
#
# Defaults are conservative: copy files, prompt before replacing targets, and
# move replaced targets into ~/.dotfiles-backup/<timestamp>/.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/platform.sh
source "$SCRIPT_DIR/lib/platform.sh"

COLOR_RED="\033[0;31m"
COLOR_GREEN="\033[0;32m"
COLOR_YELLOW="\033[0;33m"
COLOR_BLUE="\033[0;34m"
COLOR_RESET="\033[0m"

log_info()    { echo -e "${COLOR_BLUE}[INFO]${COLOR_RESET} $1"; }
log_warn()    { echo -e "${COLOR_YELLOW}[WARN]${COLOR_RESET} $1"; }
log_error()   { echo -e "${COLOR_RED}[ERROR]${COLOR_RESET} $1"; }
log_success() { echo -e "${COLOR_GREEN}[OK]${COLOR_RESET} $1"; }

MODE="copy"
ASSUME_YES=0
DRY_RUN=0
USE_BACKUP=1
BACKUP_ROOT=""
PLATFORM=""
MACHINE=""

usage() {
    cat <<'EOF'
Usage: ./restore [OPTIONS]

Options:
  --copy                    Copy files into place. This is the default.
  --link                    Symlink files/directories back to this repo.
  --platform linux|mac|hep  Override auto-detected platform.
  --machine NAME            HEP machine name for selecting machine_aliases
                            (default: hostname -s). Known: lxplus, sneezy,
                            sleepy, gpu_farm.
  -y, --yes                 Do not prompt before replacing existing targets.
  -n, --dry-run             Show what would happen without changing files.
  --no-backup               Do not move existing targets to a backup first.
  -h, --help                Show this help.

Environment:
  DOTFILES_BACKUP_DIR  Override the backup directory.
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --copy)
                MODE="copy"
                ;;
            --link)
                MODE="link"
                ;;
            --platform)
                shift
                [[ -z "${1:-}" ]] && { log_error "--platform requires a value (linux|mac|hep)"; exit 2; }
                PLATFORM="$1"
                ;;
            --machine)
                shift
                [[ -z "${1:-}" ]] && { log_error "--machine requires a value (e.g. lxplus, sneezy)"; exit 2; }
                MACHINE="$1"
                ;;
            -y|--yes)
                ASSUME_YES=1
                ;;
            -n|--dry-run)
                DRY_RUN=1
                ;;
            --no-backup)
                USE_BACKUP=0
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                usage
                exit 2
                ;;
        esac
        shift
    done
}

confirm() {
    local message="$1"

    if [[ "$ASSUME_YES" -eq 1 ]]; then
        return 0
    fi

    if [[ ! -t 0 ]]; then
        log_warn "No terminal available for prompt: $message"
        return 1
    fi

    local reply
    read -rp "$(echo -e "${COLOR_YELLOW}[?]${COLOR_RESET} $message (y/N): ")" reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

run() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        printf 'DRY-RUN:'
        printf ' %q' "$@"
        printf '\n'
    else
        "$@"
    fi
}

check_deps() {
    local deps=(cp ln mkdir mv)

    if [[ "$MODE" == "copy" ]]; then
        deps+=(rsync)
    fi

    local dep
    for dep in "${deps[@]}"; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            log_error "Missing required command: $dep"
            exit 1
        fi
    done
}

same_link() {
    local src="$1"
    local dest="$2"

    [[ -L "$dest" ]] || return 1
    [[ "$(readlink "$dest")" == "$src" ]]
}

same_file() {
    local src="$1"
    local dest="$2"

    [[ -f "$src" && -f "$dest" ]] || return 1
    cmp -s "$src" "$dest"
}

backup_existing() {
    local dest="$1"
    local rel backup_dest

    if [[ "$dest" == "$HOME/"* ]]; then
        rel="${dest#"$HOME"/}"
    else
        rel="${dest#/}"
    fi

    backup_dest="$BACKUP_ROOT/$rel"
    run mkdir -p "$(dirname "$backup_dest")"
    run mv "$dest" "$backup_dest"
    log_info "Backed up existing target: $dest -> $backup_dest"
}

prepare_target() {
    local src="$1"
    local dest="$2"

    if [[ "$MODE" == "link" ]] && same_link "$src" "$dest"; then
        log_success "Already linked: $dest"
        return 1
    fi

    if [[ "$MODE" == "copy" ]] && same_file "$src" "$dest"; then
        log_success "Already current: $dest"
        return 1
    fi

    if [[ -e "$dest" || -L "$dest" ]]; then
        if [[ "$USE_BACKUP" -eq 1 ]]; then
            confirm "Replace existing target with backup first: $dest" || {
                log_info "Skipped: $dest"
                return 1
            }
            backup_existing "$dest"
        else
            confirm "Replace existing target without backup: $dest" || {
                log_info "Skipped: $dest"
                return 1
            }
            if [[ "$MODE" == "link" ]]; then
                log_error "--link with --no-backup cannot replace an existing target safely: $dest"
                return 1
            fi
        fi
    fi

    run mkdir -p "$(dirname "$dest")"
    return 0
}

restore_path() {
    local src="$1"
    local dest="$2"

    if [[ ! -e "$src" ]]; then
        log_warn "Source not found: $src"
        return 0
    fi

    prepare_target "$src" "$dest" || return 0

    if [[ "$MODE" == "link" ]]; then
        run ln -s "$src" "$dest"
        log_success "Linked: $dest -> $src"
    elif [[ -d "$src" ]]; then
        run mkdir -p "$dest"
        run rsync -a "$src/" "$dest/"
        log_success "Copied dir: $src -> $dest"
    else
        run cp "$src" "$dest"
        log_success "Copied file: $src -> $dest"
    fi
}

restore_hep() {
    local repo_root="$1"
    local machine="${MACHINE:-}"
    if [[ -z "$machine" ]]; then
        machine="$(hostname -s 2>/dev/null || hostname)"
    fi

    log_info "HEP restore for machine: $machine"

    restore_path "$repo_root/hep/bash/.bashrc"         "$HOME/.bashrc"
    restore_path "$repo_root/hep/bash/.bash_aliases"   "$HOME/.bash_aliases"
    restore_path "$repo_root/hep/bash/.bash_config"    "$HOME/.bash_config"
    restore_path "$repo_root/hep/bash/.bash_functions" "$HOME/.bash_functions"

    local aliases_file="$repo_root/hep/machine_aliases/$machine"
    if [[ -f "$aliases_file" ]]; then
        restore_path "$aliases_file" "$HOME/.machine_aliases"
    else
        log_warn "No machine_aliases file for '$machine'. Available: $(ls "$repo_root/hep/machine_aliases/" 2>/dev/null | tr '\n' ' ')"
        log_warn "Re-run with --machine NAME to select one."
    fi
}

restore_mac() {
    local repo_root="$1"
    # mac/setup.sh does not understand --dry-run; warn before it makes real changes.
    [[ "$DRY_RUN" -eq 1 ]] && log_warn "--dry-run is not supported for mac platform: setup.sh will run and make real changes"
    log_info "Mac restore via mac/setup.sh"
    cd "$repo_root/mac"
    exec bash setup.sh
}

restore_all() {
    local repo_root="$1"
    local zsh_file filename

    # SSH
    restore_path "$repo_root/ssh/config" "$HOME/.ssh/config"
    # SSH is strict about directory permissions; fix regardless of whether we just created it.
    [[ -d "$HOME/.ssh" ]] && run chmod 700 "$HOME/.ssh"

    # Git
    restore_path "$repo_root/git/.gitconfig" "$HOME/.gitconfig"
    restore_path "$repo_root/git/.stCommitMsg" "$HOME/.stCommitMsg"

    # POSIX shell and Bash
    restore_path "$repo_root/sh/.profile" "$HOME/.profile"
    restore_path "$repo_root/bash/.bashrc" "$HOME/.bashrc"

    # Zsh explicit hidden files
    restore_path "$repo_root/zsh/.zshenv" "$HOME/.zshenv"
    restore_path "$repo_root/zsh/.zprofile" "$HOME/.zprofile"
    restore_path "$repo_root/zsh/.zshrc" "$HOME/.zshrc"

    # Zsh module directories used by .zshrc.
    restore_path "$repo_root/zsh/core" "$HOME/.config/dotfiles/zsh/core"
    restore_path "$repo_root/zsh/aliases" "$HOME/.config/dotfiles/zsh/aliases"
    restore_path "$repo_root/zsh/functions" "$HOME/.config/dotfiles/zsh/functions"
    restore_path "$repo_root/zsh/integrations" "$HOME/.config/dotfiles/zsh/integrations"

    # Zsh modular files go directly under $HOME.
    # These are compatibility wrappers for older setups that source them.
    shopt -s nullglob
    for zsh_file in "$repo_root"/zsh/*.zsh; do
        filename="$(basename "$zsh_file")"
        restore_path "$zsh_file" "$HOME/$filename"
    done
    shopt -u nullglob

    # CLI scripts
    restore_path "$repo_root/cli" "$HOME/cli"

    # Terminal configs
    restore_path "$repo_root/terminals/ghostty" "$HOME/.config/ghostty"
    restore_path "$repo_root/terminals/waveterm/config" "$HOME/.waveterm/config"
}

main() {
    parse_args "$@"

    local repo_root timestamp
    repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    timestamp="$(date +%Y%m%d-%H%M%S)"
    BACKUP_ROOT="${DOTFILES_BACKUP_DIR:-$HOME/.dotfiles-backup/$timestamp}"

    if [[ -z "$PLATFORM" ]]; then
        PLATFORM="$(detect_platform)"
    fi

    log_info "Repo root: $repo_root"
    log_info "Platform:  $PLATFORM"
    log_info "Mode: $MODE"
    [[ "$DRY_RUN" -eq 1 ]] && log_warn "Dry run only; no files will be changed."

    case "$PLATFORM" in
        linux)
            [[ "$USE_BACKUP" -eq 1 ]] && log_info "Backup root: $BACKUP_ROOT"
            check_deps
            restore_all "$repo_root"
            log_success "Dotfile restoration complete."
            log_info "Run 'exec zsh' or restart your terminal to apply shell changes."
            ;;
        hep)
            # rsync is not used in HEP restore (individual files only, no dirs),
            # so skip check_deps to avoid requiring rsync on clusters that lack it.
            [[ "$USE_BACKUP" -eq 1 ]] && log_info "Backup root: $BACKUP_ROOT"
            restore_hep "$repo_root"
            log_success "HEP dotfile restoration complete."
            log_info "Run 'source ~/.bashrc' to apply shell changes."
            ;;
        mac)
            restore_mac "$repo_root"
            ;;
        *)
            log_error "Unknown platform: $PLATFORM"
            exit 1
            ;;
    esac
}

main "$@"
